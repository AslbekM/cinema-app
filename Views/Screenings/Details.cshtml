@model tickets.ViewModels.ScreeningSeatsVm

@{
    ViewData["Title"] = "Seats";
    var returnUrl = Url.Action("Details", "Screenings", new { id = Model.ScreeningId });
}

<h2>@Model.FilmTitle</h2>
<p><strong>Date and time:</strong> @Model.StartTime.ToString("yyyy-MM-dd HH:mm")</p>
<p><strong>Cinema:</strong> @Model.CinemaName</p>

@if (TempData["SeatSuccess"] != null)
{
    <div class="alert alert-success">@TempData["SeatSuccess"]</div>
}

@if (TempData["SeatError"] != null)
{
    <div class="alert alert-danger">@TempData["SeatError"]</div>
}

@if (!Model.IsLoggedIn)
{
    <div class="alert alert-warning">
        To reserve a seat, please
        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">log in</a>
        or
        <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@returnUrl">register</a>.
    </div>
}

<div class="mb-4">
    <strong>Screen</strong>
    <div style="height: 10px; background-color: #ccc; border-radius: 10px; margin-top: 8px;"></div>
</div>

@for (int row = 1; row <= Model.Rows; row++)
{
    <div class="mb-2">
        <strong>Row @row</strong>
        <div class="d-flex flex-wrap gap-2 mt-2">
            @for (int seat = 1; seat <= Model.SeatsPerRow; seat++)
            {
                var key = $"{row}-{seat}";
                var taken = Model.ReservedSeats.Contains(key);
                var mine = Model.MySeats.Contains(key);

                if (mine)
                {
                    <form asp-controller="Reservations" asp-action="Cancel" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="screeningId" value="@Model.ScreeningId" />
                        <input type="hidden" name="rowNumber" value="@row" />
                        <input type="hidden" name="seatNumber" value="@seat" />
                        <button type="submit" class="btn btn-warning btn-sm">
                            @seat
                        </button>
                    </form>
                }
                else if (taken)
                {
                    <button class="btn btn-danger btn-sm" disabled>
                        @seat
                    </button>
                }
                else if (Model.IsLoggedIn)
                {
                    <form asp-controller="Reservations" asp-action="Reserve" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="screeningId" value="@Model.ScreeningId" />
                        <input type="hidden" name="rowNumber" value="@row" />
                        <input type="hidden" name="seatNumber" value="@seat" />
                        <button type="submit" class="btn btn-success btn-sm">
                            @seat
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account"
                       asp-action="Login"
                       asp-route-returnUrl="@returnUrl"
                       class="btn btn-outline-primary btn-sm">
                        @seat
                    </a>
                }
            }
        </div>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>