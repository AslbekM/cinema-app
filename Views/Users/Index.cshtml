@model IEnumerable<tickets.Models.AppUser>

@{
    ViewData["Title"] = "Users";
}

<h2>Users</h2>

@if (TempData["UserSuccess"] != null)
{
    <div class="alert alert-success">@TempData["UserSuccess"]</div>
}

@if (TempData["UserError"] != null)
{
    <div class="alert alert-danger">@TempData["UserError"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>First name</th>
            <th>Last name</th>
            <th>Email</th>
            <th>Nickname</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.FirstName</td>
            <td>@user.LastName</td>
            <td>@user.Email</td>
            <td>@user.UserName</td>
            <td>
                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary btn-sm me-1">Edit</a>
                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>